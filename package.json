{
  "name": "chatbutler",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "description": "AI 智能体对话平台",
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@chatbutler/web",
    "dev:server": "turbo dev --filter=@chatbutler/server",
    "dev:admin": "pnpm --filter @chatbutler/admin dev",
    "dev:desktop": "turbo dev --filter=@chatbutler/desktop",
    "build": "turbo build",
    "build:web": "turbo build --filter=@chatbutler/web",
    "build:server": "turbo build --filter=@chatbutler/server",
    "build:desktop": "turbo build --filter=@chatbutler/desktop",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:watch": "turbo test:watch",
    "type-check": "turbo type-check",
    "db:generate": "pnpm --filter @chatbutler/server prisma:generate",
    "db:migrate": "pnpm --filter @chatbutler/server prisma:migrate",
    "db:seed": "pnpm --filter @chatbutler/server prisma:seed",
    "db:studio": "pnpm --filter @chatbutler/server prisma:studio",
    "db:init": "pnpm db:generate && pnpm db:migrate && pnpm db:seed",
    "setup:check": "tsx scripts/check-env.ts",
    "setup:docker": "docker compose -f docker-compose.dev.yml up -d",
    "setup:env": "tsx scripts/copy-env.ts",
    "setup:all": "pnpm setup:check && pnpm install && pnpm setup:docker && pnpm setup:env && pnpm db:init",
    "docker:up": "docker compose -f docker-compose.dev.yml up -d",
    "docker:down": "docker compose -f docker-compose.dev.yml down",
    "docker:reset": "docker compose -f docker-compose.dev.yml down -v",
    "clean": "turbo clean && rimraf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "rimraf": "^6.0.0",
    "@types/node": "^20.17.0",
    "prettier": "^3.4.0",
    "eslint": "^9.17.0"
  }
}
