  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.2.0",
    "@nestjs/testing": "^10.4.0",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.0",
    "@types/passport-jwt": "^4.0.1",
    "jest": "^29.7.0",
    "prisma": "^6.2.0",
    "rimraf": "^6.0.0",
    "ts-jest": "^29.2.0",
    "ts-loader": "^9.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
